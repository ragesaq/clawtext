[Unit]
Description=ClawText nightly cluster rebuild + validation + journal maintenance
ConditionPathExists=%h/.openclaw/workspace/repo/clawtext/scripts/system-cron/clawtext-daily-cluster-rebuild.sh

[Service]
Type=oneshot
WorkingDirectory=%h/.openclaw/workspace/repo/clawtext
ExecStart=%h/.openclaw/workspace/repo/clawtext/scripts/system-cron/clawtext-daily-cluster-rebuild.sh
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=read-only
ReadWritePaths=%h/.openclaw/workspace
Nice=10
IOSchedulingClass=best-effort
