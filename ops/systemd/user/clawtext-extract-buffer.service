[Unit]
Description=ClawText extract-buffer deterministic maintenance job
ConditionPathExists=%h/.openclaw/workspace/repo/clawtext/scripts/system-cron/clawtext-extract-buffer.sh

[Service]
Type=oneshot
WorkingDirectory=%h/.openclaw/workspace/repo/clawtext
ExecStart=%h/.openclaw/workspace/repo/clawtext/scripts/system-cron/clawtext-extract-buffer.sh
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=read-only
ReadWritePaths=%h/.openclaw/workspace
Nice=10
IOSchedulingClass=best-effort
