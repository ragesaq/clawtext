[Unit]
Description=ClawText weekly operational maintenance sweep
ConditionPathExists=%h/.openclaw/workspace/repo/clawtext/scripts/system-cron/clawtext-operational-maintenance.sh

[Service]
Type=oneshot
WorkingDirectory=%h/.openclaw/workspace/repo/clawtext
ExecStart=%h/.openclaw/workspace/repo/clawtext/scripts/system-cron/clawtext-operational-maintenance.sh
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=read-only
ReadWritePaths=%h/.openclaw/workspace
Nice=10
IOSchedulingClass=best-effort
