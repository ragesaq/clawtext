{
  "name": "clawtext",
  "version": "1.4.0",
  "description": "Comprehensive memory platform for OpenClaw agents — tiered retrieval, bulk ingest, and operational self-improvement",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "clawtext-ingest": "bin/ingest.js",
    "clawtext-ingest-discord": "bin/discord.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node test.mjs",
    "cache:stats": "node scripts/cache-stats.mjs",
    "curation:stats": "node scripts/curation-stats.mjs",
    "review:digest": "node scripts/review-digest.mjs",
    "review:dedupe": "node scripts/review-dedupe.mjs",
    "health": "node scripts/health-report.mjs",
    "install-deps": "node install.js",
    "memory": "node cli.mjs",
    "ingest:dedupe": "node scripts/ingest-dedupe.mjs",
    "ingest:dedupe:watch": "node scripts/ingest-dedupe.mjs --watch",
    "ingest:all": "node scripts/ingest-all.mjs",
    "ingest:discord": "node bin/discord.js fetch-discord",
    "ingest:describe": "node bin/discord.js describe-forum",
    "knowledge:status": "node scripts/knowledge-repos.mjs status",
    "operational:status": "node scripts/operational-cli.mjs status",
    "operational:review": "node scripts/operational-cli.mjs review",
    "operational:review:queue": "node scripts/operational-cli.mjs review:queue",
    "operational:review:stats": "node scripts/operational-cli.mjs review:stats",
    "operational:search": "node scripts/operational-cli.mjs search",
    "operational:promote": "node scripts/operational-cli.mjs promote",
    "operational:capture:error": "node scripts/operational-cli.mjs capture:error",
    "operational:capture:success": "node scripts/operational-cli.mjs capture:success",
    "operational:transfer-check": "node scripts/operational-cli.mjs transfer-check",
    "operational:aggregation:stats": "node scripts/operational-cli.mjs aggregation:stats",
    "operational:synthesize": "node scripts/operational-cli.mjs synthesize",
    "operational:merge:find": "node scripts/operational-cli.mjs merge:find",
    "operational:merge": "node scripts/operational-cli.mjs merge",
    "operational:correlate": "node scripts/operational-cli.mjs correlate",
    "operational:report": "node scripts/operational-cli.mjs report",
    "operational:maintenance:status": "node scripts/operational-cli.mjs maintenance:status",
    "operational:maintenance:run": "node scripts/operational-cli.mjs maintenance:run",
    "operational:maintenance:force-due": "node scripts/operational-cli.mjs maintenance:force-due",
    "operational:retrieval:test": "node scripts/operational-cli.mjs retrieval:test",
    "operational:retrieval:health": "node scripts/operational-cli.mjs retrieval:health"
  },
  "keywords": [
    "memory",
    "rag",
    "context-injection",
    "ingest",
    "discord",
    "operational-learning",
    "self-improvement",
    "openclaw"
  ],
  "dependencies": {
    "discord.js": "^14.25.1",
    "glob": "^10.3.10",
    "js-yaml": "^4.1.0",
    "openclaw": "^2026.3.1",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.3.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
