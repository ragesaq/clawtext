{
  "name": "@psiclawops/clawtext",
  "version": "0.2.0",
  "description": "Layered memory and continuity platform for OpenClaw agents: working memory, ingest, operational learning, ClawBridge transfer, and trusted documentation library retrieval.",
  "repository": {
    "type": "git",
    "url": "https://github.com/PsiClawOps/clawtext.git"
  },
  "homepage": "https://github.com/PsiClawOps/clawtext",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "clawtext": "./scripts/cli.js"
  },
  "scripts": {
    "build": "tsc && node scripts/add-js-extensions.js",
    "dev": "tsc --watch",
    "extract:buffer": "node scripts/extract-buffer.mjs",
    "breadcrumb:log": "node scripts/log-memory-evolution-breadcrumb.mjs",
    "eval:memory-evolution": "node scripts/eval-memory-evolution.mjs",
    "memory:report": "node scripts/memory-health-report.js",
    "library:ingest": "node scripts/library-ingest.mjs",
    "library:index": "node scripts/library-index.mjs",
    "library:smoke": "node scripts/library-retrieval-smoke.mjs",
    "journal:restore": "node scripts/restore-context.mjs",
    "journal:restore:inject": "node scripts/restore-context.mjs --format inject"
  },
  "keywords": [
    "memory",
    "rag",
    "context-injection",
    "agent-memory",
    "semantic-clustering",
    "operational-learning",
    "self-healing"
  ],
  "author": "PsiClawOps",
  "license": "MIT",
  "dependencies": {
    "js-yaml": "^4.1.0",
    "openclaw": "^2026.3.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.3.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "skills": [
      "./docs"
    ]
  }
}
