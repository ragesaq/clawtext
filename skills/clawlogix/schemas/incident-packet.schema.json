{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RestartControlIncidentPacket",
  "type": "object",
  "required": ["id", "createdAt", "phase", "status", "detectors", "snapshot", "classification"],
  "properties": {
    "id": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "phase": { "type": "string", "enum": ["containment", "diagnosis", "mitigation", "resolved"] },
    "status": { "type": "string", "enum": ["open", "acknowledged", "mitigating", "resolved", "dismissed"] }
  }
}
