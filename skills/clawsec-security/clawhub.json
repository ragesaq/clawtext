{
  "name": "clawsec-security",
  "version": "1.0.0",
  "description": "Enterprise-grade web search security for OpenClaw",
  "author": "ragesaq",
  "license": "proprietary",
  "keywords": [
    "security",
    "web-search",
    "injection-detection",
    "typoglycemia",
    "rate-limiting",
    "audit"
  ],
  "category": "security",
  "tags": [
    "security",
    "web-search",
    "protection",
    "validation"
  ],
  "features": [
    "Automatic web_search protection",
    "Typoglycemia attack detection",
    "15+ injection pattern detection",
    "Output guard for search results",
    "Rate limiting (Best-of-N)",
    "Full audit logging",
    "Real-time blocking"
  ],
  "requirements": {
    "openclaw": ">=2026.3.0",
    "python": ">=3.9"
  },
  "installation": {
    "type": "skill",
    "path": "./skills/clawsec-security",
    "hook": "clawsec-security"
  },
  "configuration": {
    "hooks": {
      "internal": {
        "entries": {
          "clawsec-security": {
            "enabled": true
          }
        }
      }
    }
  },
  "metrics": {
    "attack_success_rate": "<1%",
    "validation_latency": "<10ms",
    "typoglycemia_detection": ">85%",
    "test_coverage": "8/8"
  },
  "documentation": {
    "readme": "README.md",
    "api": "docs/API.md",
    "examples": "examples/"
  },
  "support": {
    "issues": "https://github.com/ragesaq/clawsec-security/issues",
    "docs": "https://docs.example.com/clawsec"
  }
}
